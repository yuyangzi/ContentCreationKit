{
  "name": "微信原生",
  "description": "微信绿 #07c160 原生风格，适合官方/正式/通用内容",
  "colors": {
    "primary": "#333333",
    "accent": "#07c160",
    "background": "#ffffff",
    "blockquote_bg": "#f0f7f2",
    "code_bg": "#f0f7f2",
    "hr_color": "#07c160",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "29px",
      "font_weight": "700",
      "color": "#163325",
      "line_height": "1.32",
      "margin_top": "36px",
      "margin_bottom": "18px",
      "letter_spacing": "-0.015em",
      "padding": "12px 16px 11px",
      "border_left": "5px solid #07c160",
      "border_radius": "12px",
      "background": "linear-gradient(180deg, rgba(7,193,96,0.08) 0%, rgba(7,193,96,0.03) 100%)",
      "border_bottom": "1px dashed rgba(22,51,37,0.2)",
      "box_shadow": "0 6px 14px rgba(7,193,96,0.05)"
    },
    "h2": {
      "font_size": "23px",
      "font_weight": "700",
      "color": "#067647",
      "line_height": "1.4",
      "margin_top": "34px",
      "margin_bottom": "18px",
      "padding": "10px 14px",
      "border_left": "4px solid #07c160",
      "border_radius": "12px",
      "background": "linear-gradient(90deg, rgba(7,193,96,0.12) 0%, rgba(7,193,96,0.03) 70%, rgba(7,193,96,0) 100%)"
    },
    "h3": {
      "font_size": "21px",
      "font_weight": "600",
      "color": "#1f3d2d",
      "line_height": "1.45",
      "margin_top": "28px",
      "margin_bottom": "14px",
      "padding_left": "12px",
      "border_left": "3px solid rgba(7,193,96,0.9)",
      "padding": "0 0 6px 12px"
    },
    "p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "18px",
      "letter_spacing": "0.02em",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "4px solid #07c160",
      "background": "linear-gradient(135deg, #f0f7f2 0%, #f8fcf9 100%)",
      "padding": "16px 20px",
      "border_radius": "12px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "15px",
      "color": "rgba(7,193,96,0.7)",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.02em",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "700",
      "color": "#067647",
      "background": "linear-gradient(180deg, rgba(7,193,96,0) 0%, rgba(7,193,96,0) 58%, rgba(7,193,96,0.16) 58%, rgba(7,193,96,0.16) 100%)",
      "padding": "0 3px"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#07c160",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "36px",
      "margin_bottom": "36px",
      "height": "2px",
      "width": "62%",
      "background": "linear-gradient(90deg, rgba(7,193,96,0) 0%, rgba(7,193,96,0.22) 20%, rgba(7,193,96,0.68) 50%, rgba(7,193,96,0.22) 80%, rgba(7,193,96,0) 100%)",
      "border": "none"
    },
    "code": {
      "background": "#f0f7f2",
      "padding": "3px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#07c160",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#f0f7f2",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "rgba(7,193,96,0.15)"
    },
    "pre": {
      "background": "#f0f7f2",
      "color": "#07c160",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#07c160",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "#f0f7f2",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#333333",
      "border": "1px solid #d8e8dc"
    },
    "td": {
      "padding": "12px 16px",
      "border": "1px solid #d8e8dc",
      "color": "#333333"
    },
    "list_item_bullet": {
      "color": "#07c160",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(7,193,96,0.1)",
      "color": "#07c160",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#333333",
      "line_height": "1.75",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#07c160",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(7,193,96,0.08)",
      "border_left": "4px solid #07c160",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#07c160",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#1f3d2d",
      "border_left": "2px solid #07c160",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "19px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "color": "#07c160"
    },
    "h2": {
      "color": "#07c160"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(7,193,96, 0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(7,193,96, 0.2)"
    }
  }
}