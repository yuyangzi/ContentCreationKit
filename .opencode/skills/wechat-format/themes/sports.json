{
  "name": "运动",
  "description": "运动绿 #00A968 + 渐变色带，活力动感，适合体育/健身/户外内容",
  "colors": {
    "primary": "#2c2c2c",
    "accent": "#00A968",
    "background": "#ffffff",
    "blockquote_bg": "#f8f8f8",
    "code_bg": "#282c34",
    "hr_color": "#00A968",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#ffffff",
      "text_align": "center",
      "letter_spacing": "0.12em",
      "line_height": "1.4",
      "background": "linear-gradient(120deg, #00A968, #008A56, #00A968)",
      "border_radius": "50px",
      "padding": "12px 24px",
      "box_shadow": "0 8px 20px rgba(0, 169, 104, 0.3)",
      "margin_top": "24px",
      "margin_bottom": "12px"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#00A968",
      "text_align": "left",
      "letter_spacing": "0.06em",
      "line_height": "1.4",
      "background": "linear-gradient(to right, rgba(0, 169, 104, 0.05), rgba(56, 198, 244, 0.05))",
      "border_left": "4px solid",
      "border_image": "linear-gradient(to bottom, #FF6600, #00A968, #38C6F4) 1",
      "border_radius": "0 12px 12px 0",
      "padding": "8px 16px",
      "box_shadow": "0 3px 8px rgba(0, 169, 104, 0.12)",
      "margin_top": "32px",
      "margin_bottom": "12px"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#00A968",
      "letter_spacing": "0.08em",
      "border_left": "4px solid",
      "border_image": "linear-gradient(to bottom, #FF6600, #00A968, #38C6F4) 1",
      "background": "linear-gradient(to right, rgba(255, 102, 0, 0.05), rgba(0, 169, 104, 0.05))",
      "border_radius": "0 25px 25px 0",
      "padding": "8px 20px",
      "margin_top": "28px",
      "margin_bottom": "12px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "16px",
      "letter_spacing": "0.02em",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "5px solid",
      "border_image": "linear-gradient(to bottom, #FF6600, #00A968, #38C6F4) 1",
      "background": "#f8f8f8",
      "padding": "16px 20px",
      "border_radius": "0 8px 8px 0",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "15px",
      "color": "#3c3c3e",
      "line_height": "1.8"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#3c3c3e",
      "line_height": "1.8",
      "margin_bottom": "0",
      "letter_spacing": "0.02em"
    },
    "strong": {
      "font_weight": "700",
      "color": "#00A968"
    },
    "em": {
      "font_style": "italic",
      "color": "#00A968"
    },
    "a": {
      "color": "#00A968",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "3px",
      "background": "linear-gradient(to right, rgba(255,102,0,0), #FF6600, #00A968, #38C6F4, rgba(56,198,244,0))",
      "border": "none"
    },
    "code": {
      "background": "linear-gradient(135deg, rgba(0,169,104,0.1), rgba(56,198,244,0.1))",
      "padding": "3px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#00A968",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#ffffff",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "box_shadow": "0 8px 25px rgba(0,0,0,0.2)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "linear-gradient(to right, #FF6600, #00A968, #38C6F4)"
    },
    "pre": {
      "background": "#ffffff",
      "color": "#2c2c2c",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.6",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#2c2c2c",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "linear-gradient(135deg, rgba(255,102,0,0.1), rgba(0,169,104,0.1))",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#00A968",
      "border_bottom": "2px solid rgba(255,102,0,0.2)"
    },
    "td": {
      "padding": "10px 16px",
      "border_bottom": "1px solid rgba(0,0,0,0.08)",
      "color": "#2c2c2c"
    },
    "list_item_bullet": {
      "color": "#00A968",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(0,169,104,0.1)",
      "color": "#00A968",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.8",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#00A968",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(0,169,104,0.08)",
      "border_left": "4px solid #00A968",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#00A968",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#2c2c2c",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "bold",
      "color": "#00A968",
      "border_left": "2px solid #00A968",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "bgcolor": "#008A56",
      "color": "#ffffff"
    },
    "h2": {
      "color": "#00C878"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(0,169,104,0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(0,169,104,0.2)"
    }
  }
}