{
  "name": "GitHub",
  "description": "GitHub 蓝 #0969DA 强调，灰色边框系统，白底开发者风格，适合技术博客、代码分享",
  "colors": {
    "primary": "#1f2328",
    "accent": "#0969da",
    "background": "#ffffff",
    "blockquote_bg": "#f6f8fa",
    "code_bg": "#f6f8fa",
    "hr_color": "#0969da",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "29px",
      "font_weight": "700",
      "color": "#1f2328",
      "line_height": "1.26",
      "padding": "12px 16px 11px",
      "border": "1px solid #d8dee4",
      "border_left": "5px solid #0969da",
      "border_radius": "10px",
      "background": "linear-gradient(180deg, #f8fbff 0%, #f6f8fa 100%)",
      "box_shadow": "0 1px 0 rgba(31,35,40,0.04)",
      "margin_top": "36px",
      "margin_bottom": "18px"
    },
    "h2": {
      "font_size": "23px",
      "font_weight": "700",
      "color": "#1f2328",
      "line_height": "1.35",
      "padding": "0 0 10px 0",
      "border_bottom": "2px solid #d8dee4",
      "box_shadow": "inset 0 -2px 0 #0969da",
      "margin_top": "34px",
      "margin_bottom": "18px"
    },
    "h3": {
      "font_size": "21px",
      "font_weight": "600",
      "color": "#1f2328",
      "line_height": "1.4",
      "padding_left": "12px",
      "border_left": "3px solid #218bff",
      "letter_spacing": "0.01em",
      "margin_top": "28px",
      "margin_bottom": "14px"
    },
    "p": {
      "font_size": "15px",
      "color": "#1f2328",
      "line_height": "1.6",
      "margin_top": "0",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px",
      "text_align": "left"
    },
    "blockquote": {
      "border": "1px solid #d8dee4",
      "border_left": "4px solid #218bff",
      "background": "#f6f8fa",
      "padding": "14px 16px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "border_radius": "10px",
      "font_size": "16px",
      "color": "#57606a",
      "line_height": "1.6"
    },
    "blockquote_p": {
      "font_size": "16px",
      "color": "#1f2328",
      "line_height": "1.6",
      "margin_bottom": "0",
      "letter_spacing": "0.3px",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "600",
      "color": "#0550ae",
      "background": "linear-gradient(180deg, rgba(9,105,218,0) 0%, rgba(9,105,218,0) 58%, rgba(9,105,218,0.14) 58%, rgba(9,105,218,0.14) 100%)",
      "padding": "0 2px",
      "display": "inline"
    },
    "em": {
      "font_style": "italic",
      "color": "#1f2328"
    },
    "a": {
      "color": "#0969da",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "6px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "8px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "34px",
      "margin_bottom": "34px",
      "height": "1px",
      "background": "linear-gradient(90deg, rgba(209,217,224,0) 0%, rgba(209,217,224,1) 16%, #0969da 50%, rgba(209,217,224,1) 84%, rgba(209,217,224,0) 100%)",
      "border": "none"
    },
    "code": {
      "background": "rgba(175,184,193,0.2)",
      "padding": "3px 6px",
      "border_radius": "6px",
      "font_size": "13px",
      "color": "#1f2328",
      "font_family": "'SF Mono', Consolas, 'Liberation Mono', Menlo, monospace"
    },
    "code_block": {
      "background": "#f6f8fa",
      "border_radius": "6px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#eef1f4"
    },
    "pre": {
      "background": "#f6f8fa",
      "color": "#1f2328",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.45",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#1f2328",
      "font_size": "13px",
      "font_family": "'SF Mono', Consolas, 'Liberation Mono', Menlo, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "#f6f8fa",
      "padding": "8px 16px",
      "border": "1px solid #d1d9e0",
      "text_align": "left",
      "font_weight": "600",
      "color": "#1f2328"
    },
    "td": {
      "padding": "8px 16px",
      "border": "1px solid #d1d9e0",
      "color": "#1f2328"
    },
    "list_item_bullet": {
      "color": "#0969da",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(9,105,218,0.1)",
      "color": "#0969da",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#1f2328",
      "line_height": "1.6",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "4px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #d8dee4"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#0969da",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(9,105,218,0.06)",
      "border_left": "4px solid #0969da",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 10px 10px 0"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#0969da",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#1f2328",
      "line_height": "1.6",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#1f2328",
      "border_left": "2px solid #0969da",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "19px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#0d1117"
    },
    "h1": {
      "bgcolor": "#161b22",
      "color": "#e6edf3"
    },
    "h2": {
      "color": "#e6edf3"
    },
    "code_block": {
      "bgcolor": "#161b22"
    },
    "code_header": {
      "bgcolor": "#0d1117"
    },
    "pre": {
      "bgcolor": "#161b22",
      "color": "#e6edf3"
    },
    "pre_code": {
      "color": "#e6edf3"
    },
    "code": {
      "bgcolor": "rgba(110,118,129,0.4)",
      "color": "#e6edf3"
    },
    "blockquote": {
      "bgcolor": "#161b22"
    },
    "img_wrapper": {
      "bgcolor": "#161b22"
    },
    "th": {
      "bgcolor": "#161b22"
    },
    "callout": {
      "bgcolor": "rgba(9,105,218,0.15)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(9,105,218,0.25)"
    }
  }
}