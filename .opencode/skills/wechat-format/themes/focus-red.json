{
  "name": "聚焦·红",
  "description": "聚焦红 #F25C54 居中标题+上下线，适合品牌/展示/营销内容",
  "colors": {
    "primary": "#2c2c2c",
    "accent": "#F25C54",
    "background": "#ffffff",
    "blockquote_bg": "rgba(242,92,84,0.05)",
    "code_bg": "#282c34",
    "hr_color": "#F25C54",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "26px",
      "font_weight": "700",
      "color": "#F25C54",
      "text_align": "center",
      "padding": "16px 0",
      "line_height": "1.4",
      "margin_top": "0",
      "margin_bottom": "28px",
      "background_image": "linear-gradient(rgba(242,92,84,0.35), rgba(242,92,84,0.35)), linear-gradient(rgba(242,92,84,0.35), rgba(242,92,84,0.35))",
      "background_size": "100% 1px, 100% 1px",
      "background_position": "center top, center bottom",
      "background_repeat": "no-repeat"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#F25C54",
      "text_align": "center",
      "padding": "12px 0",
      "line_height": "1.35",
      "margin_top": "36px",
      "margin_bottom": "24px",
      "background_image": "linear-gradient(rgba(242,92,84,0.3), rgba(242,92,84,0.3)), linear-gradient(rgba(242,92,84,0.3), rgba(242,92,84,0.3))",
      "background_size": "80% 1px, 80% 1px",
      "background_position": "center top, center bottom",
      "background_repeat": "no-repeat"
    },
    "h3": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#F25C54",
      "text_align": "center",
      "padding": "10px 0",
      "line_height": "1.4",
      "margin_top": "28px",
      "margin_bottom": "20px",
      "background_image": "linear-gradient(rgba(242,92,84,0.25), rgba(242,92,84,0.25)), linear-gradient(rgba(242,92,84,0.25), rgba(242,92,84,0.25))",
      "background_size": "70% 1px, 70% 1px",
      "background_position": "center top, center bottom",
      "background_repeat": "no-repeat"
    },
    "p": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.02em",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "5px solid #F25C54",
      "background_color": "rgba(242,92,84,0.05)",
      "padding": "16px 8px 1px 8px",
      "margin_top": "4px",
      "margin_bottom": "20px",
      "font_style": "italic",
      "line_height": "1.7"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#555555",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.02em"
    },
    "strong": {
      "font_weight": "700",
      "color": "#F25C54"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#F25C54",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "3px",
      "width": "60%",
      "background": "#F25C54",
      "border": "none"
    },
    "code": {
      "background": "rgba(242,92,84,0.1)",
      "padding": "2px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#F25C54",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#282c34",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "box_shadow": "0 2px 10px rgba(0,0,0,0.15)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#1e1e1e"
    },
    "pre": {
      "background": "#282c34",
      "color": "#d4d4d4",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#d4d4d4",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "#F25C54",
      "padding": "12px 16px",
      "text_align": "center",
      "font_weight": "600",
      "color": "#ffffff",
      "border": "1px solid rgba(242,92,84,0.2)"
    },
    "td": {
      "padding": "12px 16px",
      "border": "1px solid rgba(242,92,84,0.15)",
      "color": "#333333"
    },
    "list_item_bullet": {
      "color": "#F25C54",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(242,92,84,0.1)",
      "color": "#F25C54",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.7",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#F25C54",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(242,92,84,0.08)",
      "border_left": "4px solid #F25C54",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#F25C54",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "19px",
      "font_weight": "bold",
      "color": "#F25C54",
      "border_left": "2px solid #F25C54",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "color": "#F25C54"
    },
    "h2": {
      "color": "#F25C54"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#F25C54"
    },
    "callout": {
      "bgcolor": "rgba(242,92,84, 0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(242,92,84, 0.2)"
    }
  }
}