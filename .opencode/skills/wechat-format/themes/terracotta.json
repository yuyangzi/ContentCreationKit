{
  "name": "赤陶",
  "description": "赤陶橙 #C86442 强调，暖灰文字，白底纹理，适合知识分享、自媒体干货",
  "colors": {
    "primary": "#222222",
    "accent": "#C86442",
    "background": "#ffffff",
    "blockquote_bg": "#f7f7f7",
    "code_bg": "#3B3B3B",
    "hr_color": "#C86442",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#ffffff",
      "text_align": "center",
      "background": "#C86442",
      "border_radius": "8px",
      "padding": "12px 24px",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.2",
      "box_shadow": "0 2px 8px rgba(200,100,66,0.2)"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#3F3F3F",
      "border_left": "4px solid #C86442",
      "border_bottom": "1px dashed #C86442",
      "padding": "0 0 8px 12px",
      "margin_top": "32px",
      "margin_bottom": "12px",
      "line_height": "1.2"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#3F3F3F",
      "border_left": "3px solid #C86442",
      "padding": "0 0 6px 12px",
      "margin_top": "32px",
      "margin_bottom": "12px",
      "line_height": "1.2"
    },
    "p": {
      "font_size": "15px",
      "color": "#222222",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.5px",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "4px solid #C86442",
      "background": "#f6f6f4",
      "padding": "16px 16px 16px 32px",
      "margin_top": "24px",
      "margin_bottom": "32px",
      "border_radius": "6px",
      "font_size": "15px",
      "color": "rgba(0,0,0,0.6)",
      "line_height": "1.75",
      "font_style": "italic",
      "box_shadow": "0 4px 6px rgba(0,0,0,0.05)"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#3F3F3F",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.1em",
      "font_style": "normal",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#C86442"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#C86442",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "1px",
      "background": "linear-gradient(to right, rgba(200,100,66,0), rgba(200,100,66,0.6), rgba(200,100,66,0))",
      "border": "none"
    },
    "code": {
      "background": "rgba(200,100,66,0.1)",
      "padding": "3px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#C86442",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#fafaf9",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "border_top": "3px solid #C86442",
      "box_shadow": "0 2px 8px rgba(200,100,66,0.1)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#f0efed"
    },
    "pre": {
      "background": "#fafaf9",
      "color": "#3F3F3F",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#3F3F3F",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "#f6f6f4",
      "padding": "8px 12px",
      "border": "1px solid #e5e5e5",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#3F3F3F"
    },
    "td": {
      "padding": "8px 12px",
      "border": "1px solid #e5e5e5",
      "color": "#3F3F3F"
    },
    "list_item_bullet": {
      "color": "#C86442",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(200,100,66,0.1)",
      "color": "#C86442",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3F3F3F",
      "line_height": "1.75",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#C86442",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(200,100,66,0.08)",
      "border_left": "4px solid #C86442",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#C86442",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#3F3F3F",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "bold",
      "color": "#3F3F3F",
      "border_left": "2px solid #C86442",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "bgcolor": "#A85636",
      "color": "#ffffff"
    },
    "h2": {
      "color": "#D4825E"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(200,100,66,0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(200,100,66,0.2)"
    }
  }
}