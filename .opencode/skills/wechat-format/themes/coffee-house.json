{
  "name": "咖啡",
  "description": "咖啡棕 #8d6e63 沉稳温暖，衬线字体感，适合读书/文化/深度内容",
  "colors": {
    "primary": "#3e2723",
    "accent": "#8d6e63",
    "background": "#ffffff",
    "blockquote_bg": "#ece2d4",
    "code_bg": "#ece2d4",
    "hr_color": "#8d6e63",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "29px",
      "font_weight": "700",
      "color": "#4a302a",
      "line_height": "1.32",
      "margin_top": "36px",
      "margin_bottom": "18px",
      "letter_spacing": "-0.015em",
      "padding": "12px 16px 11px",
      "border_left": "5px solid #8d6e63",
      "border_radius": "12px",
      "background": "linear-gradient(180deg, rgba(236,226,212,0.92) 0%, rgba(245,239,230,0.94) 100%)",
      "border": "1px solid rgba(161,136,127,0.3)"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#5d4037",
      "line_height": "1.45",
      "margin_top": "34px",
      "margin_bottom": "18px",
      "padding": "0 0 8px",
      "border_left": "none",
      "border_radius": "0",
      "border_bottom": "1px solid rgba(161,136,127,0.36)",
      "background": "none"
    },
    "h3": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#4e342e",
      "line_height": "1.45",
      "margin_top": "28px",
      "margin_bottom": "14px",
      "padding_left": "12px",
      "border_left": "3px solid rgba(141,110,99,0.7)"
    },
    "p": {
      "font_size": "15px",
      "color": "#3e2723",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "18px",
      "letter_spacing": "0.02em",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "4px solid #8d6e63",
      "background": "linear-gradient(180deg, rgba(236,226,212,0.96) 0%, rgba(245,239,230,0.96) 100%)",
      "padding": "16px 20px",
      "border_radius": "12px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "15px",
      "color": "rgba(141,110,99,0.7)",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#3e2723",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.02em",
      "background": "transparent"
    },
    "strong": {
      "font_weight": "700",
      "color": "#5d4037",
      "background": "linear-gradient(180deg, rgba(93,64,55,0) 0%, rgba(93,64,55,0) 58%, rgba(161,136,127,0.22) 58%, rgba(161,136,127,0.22) 100%)",
      "padding": "0 2px"
    },
    "em": {
      "font_style": "italic",
      "color": "#795548"
    },
    "a": {
      "color": "#8d6e63",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "38px",
      "margin_bottom": "38px",
      "height": "2px",
      "width": "54%",
      "background": "linear-gradient(90deg, rgba(215,204,200,0) 0%, rgba(141,110,99,0.2) 18%, rgba(141,110,99,0.64) 50%, rgba(141,110,99,0.2) 82%, rgba(215,204,200,0) 100%)",
      "border": "none"
    },
    "code": {
      "background": "#ece2d4",
      "padding": "3px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#8d6e63",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#ece2d4",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "rgba(141,110,99,0.15)"
    },
    "pre": {
      "background": "#ece2d4",
      "color": "#6d4c41",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#6d4c41",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "background": "#ece2d4",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#3e2723",
      "border": "1px solid #d7ccc8"
    },
    "td": {
      "padding": "12px 16px",
      "border": "1px solid #d7ccc8",
      "color": "#3e2723"
    },
    "list_item_bullet": {
      "color": "#8d6e63",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(141,110,99,0.1)",
      "color": "#8d6e63",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3e2723",
      "line_height": "1.75",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#8d6e63",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(141,110,99,0.08)",
      "border_left": "4px solid #8d6e63",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#8d6e63",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#3e2723",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "19px",
      "font_weight": "bold",
      "color": "#4e342e",
      "border_left": "2px solid #8d6e63",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "color": "#8d6e63"
    },
    "h2": {
      "color": "#8d6e63"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(141,110,99, 0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(141,110,99, 0.2)"
    }
  }
}