{
  "name": "简约·灰",
  "description": "简约灰 #4E5969 极简风格，无装饰标题，适合商务/科技/专业内容",
  "colors": {
    "primary": "#2c2c2c",
    "accent": "#4E5969",
    "background": "#ffffff",
    "blockquote_bg": "#f7f7f7",
    "code_bg": "#282c34",
    "hr_color": "#4E5969",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "800",
      "color": "#4E5969",
      "margin_top": "0",
      "margin_bottom": "28px",
      "line_height": "1.4",
      "letter_spacing": "-0.03em"
    },
    "h2": {
      "font_size": "24px",
      "font_weight": "700",
      "color": "#4E5969",
      "margin_top": "36px",
      "margin_bottom": "24px",
      "line_height": "1.4",
      "letter_spacing": "-0.02em"
    },
    "h3": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#4E5969",
      "margin_top": "28px",
      "margin_bottom": "20px",
      "line_height": "1.4",
      "letter_spacing": "-0.01em"
    },
    "p": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.02em",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "3px solid #4E5969",
      "padding": "16px 8px 1px 8px",
      "margin_top": "4px",
      "margin_bottom": "20px",
      "font_style": "italic",
      "font_size": "15px",
      "color": "#555555",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#555555",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.02em"
    },
    "strong": {
      "font_weight": "700",
      "color": "#4E5969"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#4E5969",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "1px",
      "background": "rgba(78,89,105, 0.2)",
      "border": "none"
    },
    "code": {
      "background": "rgba(0,0,0,0.05)",
      "padding": "2px 4px",
      "border_radius": "2px",
      "font_size": "90%",
      "color": "#333333",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#282c34",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "box_shadow": "0 2px 10px rgba(0,0,0,0.15)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#1e1e1e"
    },
    "pre": {
      "background": "#282c34",
      "color": "#d4d4d4",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#d4d4d4",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden"
    },
    "th": {
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "700",
      "border_bottom": "2px solid rgba(0,0,0,0.15)",
      "color": "#333333"
    },
    "td": {
      "padding": "12px 16px",
      "border_bottom": "1px solid rgba(0,0,0,0.08)",
      "color": "#333333"
    },
    "list_item_bullet": {
      "color": "#4E5969",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(78,89,105, 0.1)",
      "color": "#4E5969",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.6",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#4E5969",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(78,89,105, 0.08)",
      "border_left": "4px solid #4E5969",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#4E5969",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "21px",
      "font_weight": "bold",
      "color": "#4E5969",
      "border_left": "2px solid #4E5969",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "color": "#4E5969"
    },
    "h2": {
      "color": "#4E5969"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(78,89,105, 0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(78,89,105, 0.2)"
    }
  }
}