{
  "name": "醒目·藏青",
  "description": "醒目藏青 #1F4F8A 填充标题+色块h3，适合新闻/公告/重点内容",
  "colors": {
    "primary": "#2c2c2c",
    "accent": "#1F4F8A",
    "background": "#ffffff",
    "blockquote_bg": "rgba(31,79,138,0.05)",
    "code_bg": "#282c34",
    "hr_color": "#1F4F8A",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "26px",
      "font_weight": "700",
      "color": "#ffffff",
      "background_color": "#1F4F8A",
      "padding": "16px 24px",
      "border_radius": "16px",
      "box_shadow": "0 4px 12px rgba(31,79,138,0.25)",
      "margin_top": "0",
      "margin_bottom": "28px",
      "line_height": "1.4"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "600",
      "color": "#1F4F8A",
      "padding_left": "12px",
      "border_left": "4px solid #1F4F8A",
      "margin_top": "36px",
      "margin_bottom": "24px",
      "line_height": "1.4"
    },
    "h3": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#1F4F8A",
      "padding": "6px 12px",
      "background_color": "rgba(31,79,138,0.1)",
      "border_radius": "6px",
      "border_left": "3px solid #1F4F8A",
      "margin_top": "28px",
      "margin_bottom": "20px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.02em",
      "text_align": "left"
    },
    "blockquote": {
      "border_left": "3px solid #1F4F8A",
      "background": "linear-gradient(135deg, rgba(31,79,138,0.05), rgba(31,79,138,0.02))",
      "padding": "16px 8px 1px 8px",
      "border_radius": "0 8px 8px 0",
      "margin_top": "4px",
      "margin_bottom": "20px",
      "font_size": "15px",
      "color": "#555555",
      "line_height": "1.8"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#555555",
      "line_height": "1.75",
      "margin_bottom": "0",
      "letter_spacing": "0.02em"
    },
    "strong": {
      "font_weight": "600",
      "color": "#1F4F8A"
    },
    "em": {
      "font_style": "italic",
      "color": "#444444"
    },
    "a": {
      "color": "#1F4F8A",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 12px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "10px",
      "margin_bottom": "10px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "1px",
      "width": "50%",
      "background": "linear-gradient(to right, transparent, rgba(31,79,138,0.3), rgba(31,79,138,0.3), transparent)",
      "border": "none"
    },
    "code": {
      "background": "rgba(31,79,138,0.06)",
      "padding": "2px 6px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "rgba(31,79,138,0.85)",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "code_block": {
      "background": "#282c34",
      "border_radius": "8px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "box_shadow": "0 2px 10px rgba(0,0,0,0.15)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#1e1e1e"
    },
    "pre": {
      "background": "#282c34",
      "color": "#d4d4d4",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "14px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#d4d4d4",
      "font_size": "14px",
      "font_family": "Menlo, Monaco, Consolas, 'Courier New', monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "15px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden",
      "box_shadow": "0 2px 6px rgba(31,79,138,0.04), 0 4px 12px rgba(31,79,138,0.03)"
    },
    "th": {
      "background": "linear-gradient(180deg, rgba(31,79,138,0.15) 0%, rgba(31,79,138,0.08) 100%)",
      "padding": "20px 28px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#1F4F8A",
      "border": "1px solid rgba(31,79,138,0.2)",
      "border_top": "3px solid #1F4F8A",
      "font_size": "12px",
      "letter_spacing": "1.2px"
    },
    "td": {
      "padding": "20px 28px",
      "font_size": "15px",
      "line_height": "1.75",
      "background": "#ffffff",
      "color": "#3a3a3a",
      "border": "1px solid rgba(31,79,138,0.12)"
    },
    "list_item_bullet": {
      "color": "#1F4F8A",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(31,79,138,0.1)",
      "color": "#1F4F8A",
      "border_radius": "50%",
      "font_size": "13px",
      "font_weight": "bold",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2c2c2c",
      "line_height": "1.8",
      "letter_spacing": "0.5px"
    },
    "list_wrapper": {
      "margin_top": "15px",
      "margin_bottom": "15px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed #e5e5e5"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#1F4F8A",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(31,79,138,0.08)",
      "border_left": "4px solid #1F4F8A",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 12px 12px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#1F4F8A",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#333333",
      "line_height": "1.8",
      "letter_spacing": "0.3px"
    },
    "h4": {
      "font_size": "19px",
      "font_weight": "bold",
      "color": "#1F4F8A",
      "border_left": "2px solid #1F4F8A",
      "padding": "0 0 0 8px",
      "margin_top": "24px",
      "margin_bottom": "8px",
      "line_height": "1.3"
    },
    "h5": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#555555",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    },
    "h6": {
      "font_size": "15px",
      "font_weight": "bold",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.3"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "h1": {
      "bgcolor": "#1F4F8A",
      "color": "#ffffff"
    },
    "h2": {
      "color": "#1F4F8A"
    },
    "code_block": {
      "bgcolor": "#1e1e1e"
    },
    "code_header": {
      "bgcolor": "#171717"
    },
    "pre": {
      "bgcolor": "#1e1e1e",
      "color": "#d4d4d4"
    },
    "pre_code": {
      "color": "#d4d4d4"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "bgcolor": "#262626"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(31,79,138, 0.12)"
    },
    "ol_item_bullet": {
      "bgcolor": "rgba(31,79,138, 0.2)"
    }
  }
}